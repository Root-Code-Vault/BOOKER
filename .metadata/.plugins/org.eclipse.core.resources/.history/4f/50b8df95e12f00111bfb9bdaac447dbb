package com.booker.booking_service.service.kafka.consumer;

import org.apache.kafka.clients.consumer.ConsumerRecord;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Service;

import com.booker.booking_service.entity.Booking;
import com.booker.booking_service.repository.IBookingRepository;
import com.booker.booking_service.service.kafka.producer.BookSeatKafkaEventProducer;
import com.booker.events.BookPayment;
import com.booker.events.BookSeat;

@Service
public class BookPaymentKafkaEventConsumer {

	@Autowired
	private IBookingRepository bookingRepository;

	@Autowired
	private BookSeatKafkaEventProducer producer;

	@KafkaListener(topics = "booking-payment-event")
	public void consume(ConsumerRecord<String, BookPayment> event) {
		Booking booking = bookingRepository.findById(Long.valueOf(event.value().getBookingId().toString())).get();

		if (booking != null) {
			if ("CONFIRMED".equalsIgnoreCase(event.value().getMessage().toString())) {
				booking.setStatus("CONFIRMED");
				bookingRepository.save(booking);
				
				BookSeat seat = BookSeat.newBuilder().setBookingId(booking.getId().toString())
						.setProductId(booking.getProductId().toString()).setSeatId(booking.getSeatId().toString())
						.setMessage("CONFIRMED").build();
				producer.produce(event.key(), seat);
			} else if ("FAILED".equalsIgnoreCase(event.value().getMessage().toString())) {
				booking.setStatus("FAILED");
				bookingRepository.save(booking);
				
				BookSeat seat = BookSeat.newBuilder().setBookingId(booking.getId().toString())
						.setProductId(booking.getProductId().toString()).setSeatId(booking.getSeatId().toString())
						.setMessage("FAILED").build();
				producer.produce(event.key(), seat);
			}
		}
	}
}
