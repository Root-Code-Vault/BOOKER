package com.booker.seat_service.controller;

import java.util.List;
import java.util.Objects;
import java.util.stream.Collectors;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.booker.seat_service.dto.SeatRequestDto;
import com.booker.seat_service.dto.SeatResponseDto;
import com.booker.seat_service.dto.mapper.SeatMapper;
import com.booker.seat_service.entity.Seat;
import com.booker.seat_service.service.ISeatService;

@RestController
@RequestMapping("/seat")
public class SeatController {
	@Autowired
	private ISeatService seatService;

	@GetMapping("/product/{productId}")
	public ResponseEntity<List<SeatResponseDto>> getSeatsByProduct(@PathVariable Long productId) {
		List<SeatResponseDto> seats = seatService.getSeatsByProduct(productId).stream().filter(Objects::nonNull)
				.map(SeatMapper::toDto).collect(Collectors.toList());

		return ResponseEntity.ok(seats);
	}

	@PostMapping("/create")
	public ResponseEntity<List<SeatResponseDto>> createSeat(@RequestBody List<SeatRequestDto> dto) {
		return ResponseEntity.status(HttpStatus.OK).body(seatService
				.saveSeat(dto.stream().filter(Objects::nonNull).map(SeatMapper::toEntity).collect(Collectors.toList()))
				.stream().filter(Objects::nonNull).map(SeatMapper::toDto).collect(Collectors.toList()));
	}

	@PutMapping("/book/{seatId}")
	public ResponseEntity<SeatResponseDto> bookSeat(@PathVariable Long seatId) {
		Seat booked = seatService.bookSeat(seatId);
		return ResponseEntity.ok(SeatMapper.toDto(booked));
	}

	@PutMapping("/release/{seatId}")
	public ResponseEntity<SeatResponseDto> releaseSeat(@PathVariable Long seatId) {
		Seat released = seatService.releaseSeat(seatId);
		return ResponseEntity.ok(SeatMapper.toDto(released));
	}
	
	@GetMapping("/{id}")
	public ResponseEntity<SeatResponseDto> getSeatById(@PathVariable Long id) {
		return ResponseEntity.status(HttpStatus.OK).body(SeatMapper.toDto(seatService.getSeatById(id)));
	}
}
