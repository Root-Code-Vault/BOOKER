package com.booker.booking_service.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.booker.booking_service.dto.BookingDetailsResponseDto;
import com.booker.booking_service.dto.BookingRequestDto;
import com.booker.booking_service.dto.BookingResponseDto;
import com.booker.booking_service.dto.mapper.BookingMapper;
import com.booker.booking_service.service.IBookingService;

@RestController
@RequestMapping("/booking")
public class BookingController {
	@Autowired
	private IBookingService bookingService;

	// Initiate a booking
	@PostMapping("/initiate")
	public ResponseEntity<BookingResponseDto> initiateBooking(@RequestBody BookingRequestDto dto) {
		BookingResponseDto response = bookingService.initiateBooking(dto);
		return ResponseEntity.ok().body(response);
	}

	/*
	 * @PostMapping("/cancel/{id}/{userId}") public
	 * ResponseEntity<BookingResponseDto> cancelBooking(@PathVariable Long
	 * id, @PathVariable Long userId) { return
	 * ResponseEntity.status(HttpStatus.ACCEPTED).body(BookingMapper.toDto(
	 * bookingService.cancelBooking(id, userId)));
	 * 
	 * }
	 */

	@GetMapping("/bookingDetails/{userId}")
	public ResponseEntity<List<BookingDetailsResponseDto>> getBookingDetails(@PathVariable Long userId) {
		List<BookingDetailsResponseDto> detailsList = bookingService.getBookingDetails(userId);
		return ResponseEntity.status(HttpStatus.OK).body(detailsList);
	}
}
