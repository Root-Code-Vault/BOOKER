		Seat seat = seatRepository.findById(Long.valueOf(event.value().getSeatId().toString())).get();

		if (seat != null) {
			if ("OPEN".equalsIgnoreCase(seat.getStatus())) {
				seat.setStatus("PENDING");
				seatRepository.save(seat);

				event.value().setMessage("PENDING");
				BookSeat bookSeat = event.value();
				producer.produce(event.key(), bookSeat);

			} else {
				event.value().setMessage("FAILED");
				BookSeat bookSeat = event.value();
				producer.produce(event.key(), bookSeat);
			}
		} else {
			throw new SeatNotFoundException(Long.valueOf(event.value().getSeatId().toString()));
		}

	}
