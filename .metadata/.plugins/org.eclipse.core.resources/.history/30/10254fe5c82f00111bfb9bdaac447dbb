package com.booker.seat_service.entity;

import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.Table;

@Entity
@Table(name = "BKR_SEAT_MST")
public class Seat {
	@Id
	@GeneratedValue(strategy = GenerationType.IDENTITY)
	@Column(name = "SEAT_ID", nullable = false, unique = true)
	private Long id;

	@Column(name = "SEAT_NUMBER", nullable = false)
	private String seatNumber;

	@Column(name = "SEAT_PRODUCT_ID", nullable = false)
	private Long productId; 

	@Column(name = "SEAT_STATUS", nullable = false, columnDefinition = "varchar(20) default 'OPEN'")
	private String seatStatus = "OPEN";

	public Long getId() {
		return id;
	}

	public void setId(Long id) {
		this.id = id;
	}

	public String getSeatNumber() {
		return seatNumber;
	}

	public void setSeatNumber(String seatNumber) {
		this.seatNumber = seatNumber;
	}

	public Long getProductId() {
		return productId;
	}

	public void setProductId(Long productId) {
		this.productId = productId;
	}

	public String getBooked() {
		return seatStatus;
	}

	public void setBooked(String seatStatus) {
		this.seatStatus = seatStatus;
	}

}
