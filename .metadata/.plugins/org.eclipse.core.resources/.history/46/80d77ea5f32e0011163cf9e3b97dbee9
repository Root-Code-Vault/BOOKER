		Booking booking = BookingMapper.toEntity(dto);
		// booking.setPaymentId(Long.valueOf(UUID.randomUUID().toString()));
		booking.setStatus("PENDING");
		Booking saved = bookingRepository.save(booking);

		// Publish event
		BookingInitiated event = BookingInitiated.newBuilder().setBookingId(saved.getId().toString())
				.setUserId(saved.getUserId().toString()).setProductId(saved.getProductId().toString())
				.setSeatId(saved.getSeatId().toString()).setTimestamp(String.valueOf(System.currentTimeMillis()))
				.build();

		bookingEventProducerService.publishBookingInitiated(event);

		return BookingMapper.toDto(saved);
	}

	@Override
	public Booking cancelBooking(Long id, Long userId) {
		Booking booking = bookingRepository.findByIdAndUserId(id, userId);
		if ("CONFIRMED".equalsIgnoreCase(booking.getStatus())) {
			// Publish Cancellation Event
			BookingCancelInitiated event = BookingCancelInitiated.newBuilder().setBookingId(id.toString())
					.setPaymentId(booking.getPaymentId().toString()).setProductId(booking.getProductId().toString())
					.setSeatId(booking.getSeatId().toString()).setTimestamp(String.valueOf(System.currentTimeMillis()))
					.setUserId(userId.toString()).build();

			bookingCancelProducerService.publishBookingCancellation(event);

			booking.setStatus("CANCELLATION_INITIATED");
			return bookingRepository.save(booking);
		} else {
			throw new SeatNotReservedException("Seat is not reserved for booking id: " + id);
		}
	}
