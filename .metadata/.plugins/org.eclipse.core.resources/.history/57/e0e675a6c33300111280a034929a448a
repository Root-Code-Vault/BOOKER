logging:
  level:
    root: error

spring:
  application:
    name: gateway
  cloud:
    gateway:
      default-filters:
        - JwtAuthenticationFilter

server:
  port: 8080

eureka:
  client:
    service-url:
      defaultZone: http://discovery-server:9090/eureka/
    register-with-eureka: true
    fetch-registry: true