package com.booker.seat_service.service.kafka.consumer;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Service;

import com.booker.events.BookingInitiated;
import com.booker.events.SeatReserved;
import com.booker.seat_service.entity.Seat;
import com.booker.seat_service.exception.SeatNotFoundException;
import com.booker.seat_service.repository.ISeatRepository;
import com.booker.seat_service.service.kafka.producer.SeatEventProducerService;

@Service
public class BookSeatKafkaEventConsumer {

	@Autowired
	private ISeatRepository seatRepository;

	@Autowired
	private SeatEventProducerService seatEventProducer;

	@KafkaListener(topics = "booking-events", groupId = "seat-service")
	public void consumeBookingInitiated(BookingInitiated event) {
		Seat seat = seatRepository.findById(Long.valueOf(event.getSeatId().toString()))
				.orElseThrow(() -> new SeatNotFoundException(Long.valueOf(event.getSeatId().toString())));

		if (Boolean.TRUE.equals(seat.getBooked())) {
			// Already booked → publish reserved=false
			SeatReserved reserved = SeatReserved.newBuilder().setBookingId(event.getBookingId())
					.setSeatId(event.getSeatId()).setReserved(false)
					.setTimestamp(String.valueOf(System.currentTimeMillis())).build();
			seatEventProducer.publishSeatReserved(reserved);
		} else {
			// Reserve seat
			seat.setBooked(true);
			seatRepository.save(seat);

			SeatReserved reserved = SeatReserved.newBuilder().setBookingId(event.getBookingId())
					.setSeatId(event.getSeatId()).setReserved(true)
					.setTimestamp(String.valueOf(System.currentTimeMillis())).build();
			seatEventProducer.publishSeatReserved(reserved);
		}
	}
}