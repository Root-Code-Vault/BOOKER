package com.booker.payment_service.service.kafka.consumer;

import java.time.LocalDateTime;
import java.util.UUID;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Service;

import com.booker.events.BookingInitiated;
import com.booker.events.PaymentFailed;
import com.booker.events.PaymentSuccess;
import com.booker.payment_service.entity.Payment;
import com.booker.payment_service.repository.IPaymentRepository;
import com.booker.payment_service.service.feignClient.IProductServiceClient;
import com.booker.payment_service.service.kafka.producer.PaymentEventProducerService;

@Service
public class BookingEventConsumerService {

	@Autowired
	private IPaymentRepository paymentRepository;

	@Autowired
	private IProductServiceClient productClient;

	@Autowired
	private PaymentEventProducerService paymentEventProducer;

	@KafkaListener(topics = "booking-events", groupId = "payment-service")
	public void consumeBookingInitiated(BookingInitiated event) {
		// Create Payment record
		Payment payment = new Payment();
		payment.setAmount(Double.valueOf(productClient.getProduct(event.getProductId().toString()).getPrice()));
		payment.setCreatedAt(LocalDateTime.now());
		payment.setProductId(Long.valueOf(event.getProductId().toString()));
		payment.setStatus("PENDING");
		payment.setTransactionId(UUID.randomUUID().toString());
		payment.setUserId(Long.valueOf(event.getUserId().toString()));

		Payment saved = paymentRepository.save(payment);

		if (Math.random() > 0.2) {
			PaymentSuccess success = PaymentSuccess.newBuilder().setBookingId(event.getBookingId())
					.setPaymentId(saved.getId().toString()).setProductId(event.getProductId())
					.setSeatId(event.getSeatId()).setTimestamp(saved.getCreatedAt().toString())
					.setUserId(event.getUserId()).build();
			paymentEventProducer.publishPaymentSuccess(success);

			saved.setStatus("COMPLETED");
			paymentRepository.save(payment);
		} else {
			PaymentFailed failed = PaymentFailed.newBuilder().setBookingId(event.getBookingId())
					.setPaymentId(saved.getId().toString()).setProductId(event.getProductId())
					.setSeatId(event.getSeatId()).setUserId(event.getUserId()).setReason("Insufficient funds")
					.setTimestamp(String.valueOf(System.currentTimeMillis())).build();
			paymentEventProducer.publishPaymentFailed(failed);

			saved.setStatus("FAILED");
			paymentRepository.save(payment);
		}
	}

