cors:
  allowed-origins:
    - http://localhost:8081
    - https://your-frontend.com

spring:
  application:
    name: auth-service

  datasource:
    url: jdbc:postgresql://booker-auth:5432/authdb
    username: admin
    password: password
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

  data:
    redis:
      host: booker-redis-container
      port: 6379
      database: 1
  cache:
    type: redis

logging:
  level:
    root: info
    org.springframework.web: DEBUG
    org.springframework.web.servlet.DispatcherServlet: DEBUG
    org.springframework.web.filter.CommonsRequestLoggingFilter: DEBUG
    org:
      springframework:
        jdbc: DEBUG
        orm: DEBUG

server:
  port: 9093

eureka:
  client:
    service-url:
      defaultZone: http://discovery-server:9090/eureka/
    register-with-eureka: true
    fetch-registry: true