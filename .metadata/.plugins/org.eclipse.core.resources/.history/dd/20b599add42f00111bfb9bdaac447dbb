package com.booker.seat_service.dto.mapper;

import com.booker.seat_service.dto.SeatRequestDto;
import com.booker.seat_service.dto.SeatResponseDto;
import com.booker.seat_service.entity.Seat;

public class SeatMapper {

	public static Seat toEntity(SeatRequestDto dto) {
		Seat seat = new Seat();
		seat.setSeatNumber(dto.getSeatNumber());
		seat.setProductId(Long.valueOf(dto.getProductId()));
		seat.setBooked(false);
		return seat;
	}

	public static SeatResponseDto toDto(Seat entity) {
		SeatResponseDto dto = new SeatResponseDto();
		dto.setId(entity.getId().toString());
		dto.setSeatNumber(entity.getSeatNumber());
		dto.setProductId(entity.getProductId().toString());
		dto.setBooked(entity.getBooked());
		return dto;
	}
}
