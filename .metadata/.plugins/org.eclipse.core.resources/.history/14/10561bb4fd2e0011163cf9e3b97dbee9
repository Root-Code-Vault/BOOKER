package com.booker.booking_service.service.kafka.consumer;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Service;

import com.booker.booking_service.repository.IBookingRepository;
import com.booker.events.PaymentFailed;
import com.booker.events.PaymentSuccess;

@Service
public class PaymentEventConsumerService {

    @Autowired
    private IBookingRepository bookingRepository;

    // Listener for PaymentSuccess events
    @KafkaListener(topics = "payment-events", groupId = "booking-service")
    public void consumePaymentSuccess(PaymentSuccess success) {
        bookingRepository.findById(Long.valueOf(success.getBookingId()))
            .ifPresent(booking -> {
                if ("PENDING".equalsIgnoreCase(booking.getStatus())) {
                    booking.setStatus("CONFIRMED");
                } else {
                    booking.setStatus("CANCELLED");
                }
                booking.setPaymentId(Long.valueOf(success.getPaymentId()));
                bookingRepository.save(booking);
            });
    }

    // Listener for PaymentFailed events
    @KafkaListener(topics = "payment-events", groupId = "booking-service")
    public void consumePaymentFailed(PaymentFailed failed) {
        bookingRepository.findById(Long.valueOf(failed.getBookingId()))
            .ifPresent(booking -> {
                booking.setStatus("CANCELLED");
                bookingRepository.save(booking);
            });
    }

    // Listener for cancellation events (if you use a separate topic)
    @KafkaListener(topics = "payment-cancel-events", groupId = "booking-service")
    public void consumeCancelSuccess(PaymentSuccess success) {
        bookingRepository.findById(Long.valueOf(success.getBookingId()))
            .ifPresent(booking -> {
                if ("CONFIRMED".equalsIgnoreCase(booking.getStatus())) {
                    booking.setStatus("CANCELLED");
                } else {
                    booking.setStatus("CONFIRMED");
                }
                booking.setPaymentId(Long.valueOf(success.getPaymentId()));
                bookingRepository.save(booking);
            });
    }

    @KafkaListener(topics = "payment-cancel-events", groupId = "booking-service")
    public void consumeCancelFailed(PaymentFailed failed) {
        bookingRepository.findById(Long.valueOf(failed.getBookingId()))
            .ifPresent(booking -> {
                booking.setStatus("CONFIRMED");
                bookingRepository.save(booking);
            });
    }
}
